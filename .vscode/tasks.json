{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "go build -o GoBlog",
      "options": {
        "env": {
          "GOFLAGS": "-tags=linux,libsqlite3,sqlite_fts5,gomailnotpl"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "go test",
      "options": {
        "env": {
          "GOFLAGS": "-tags=linux,libsqlite3,sqlite_fts5,gomailnotpl"
        }
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}